<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/canvasRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/lui_black">

    <!-- Background watermark -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jetbrains_mono_bold"
        android:letterSpacing="0.3"
        android:text="LUI"
        android:textColor="#03FFFFFF"
        android:textSize="120sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messageList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingTop="48dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Input bar -->
    <FrameLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@color/lui_black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="6dp"
            android:paddingEnd="0dp">

            <!-- Status dot (large tap target wrapping small dot) -->
            <FrameLayout
                android:id="@+id/statusDotTapTarget"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_gravity="center"
                    android:background="@drawable/status_dot"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Text input -->
            <EditText
                android:id="@+id/inputField"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/input_hint"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:maxLines="4"
                android:paddingStart="6dp"
                android:paddingTop="14dp"
                android:paddingEnd="4dp"
                android:paddingBottom="14dp"
                android:textColor="@color/lui_white"
                android:textColorHint="@color/lui_gray_dark"
                android:textSize="15sp" />

            <!-- Voice status label (inline, replaces hint during voice) -->
            <TextView
                android:id="@+id/voiceStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:textColor="@color/lui_gray"
                android:textSize="11sp"
                android:visibility="gone" />

            <!-- Mic button with pulse ring -->
            <FrameLayout
                android:layout_width="60dp"
                android:layout_height="48dp"
                android:paddingStart="10dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:id="@+id/micPulseRing"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="@drawable/mic_pulse_ring"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/micButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Voice input"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:tint="@color/lui_gray" />

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
