<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hubScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lui_black"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="72dp"
        android:paddingBottom="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jetbrains_mono_bold"
            android:text="Connection Hub"
            android:textColor="@color/lui_white"
            android:textSize="22sp" />

        <!-- ==================== LLM ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="LLM"
            android:textColor="@color/lui_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cloud model for reasoning. Falls back to local."
            android:textColor="@color/lui_gray_dark"
            android:textSize="11sp" />

        <RadioGroup
            android:id="@+id/providerGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rbGemini" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Gemini" android:textColor="@color/lui_white" android:textSize="12sp" />
            <RadioButton android:id="@+id/rbClaude" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Claude" android:textColor="@color/lui_white" android:textSize="12sp" />
            <RadioButton android:id="@+id/rbOpenAI" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="OpenAI" android:textColor="@color/lui_white" android:textSize="12sp" />
            <RadioButton android:id="@+id/rbOllama" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Ollama" android:textColor="@color/lui_white" android:textSize="12sp" />
        </RadioGroup>

        <EditText
            android:id="@+id/apiKeyField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="API key"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="13sp" />

        <!-- Ollama-specific fields -->
        <EditText
            android:id="@+id/ollamaEndpointField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_background"
            android:hint="Ollama endpoint (e.g., http://192.168.1.100:11434)"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="12sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/ollamaModelField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_background"
            android:hint="Model (e.g., qwen2.5:7b, llama3.1, mistral)"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cloud-first" android:textColor="@color/lui_white" android:textSize="14sp" />
            <Switch android:id="@+id/cloudFirstSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <!-- ==================== Local Model ==================== -->

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="@color/lui_divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Local Model"
            android:textColor="@color/lui_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="On-device LLM for offline use. Downloads ~400MB."
            android:textColor="@color/lui_gray_dark"
            android:textSize="11sp" />

        <!-- Model status -->
        <TextView
            android:id="@+id/localModelStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/lui_gray"
            android:textSize="12sp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/modelProgressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progressTint="@color/lui_green"
            android:progressBackgroundTint="@color/lui_gray_dark"
            android:visibility="gone" />

        <!-- Progress text (speed, size) -->
        <TextView
            android:id="@+id/modelProgressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/jetbrains_mono"
            android:textColor="@color/lui_gray"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Download / Cancel / Delete buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDownloadModel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/btn_outlined"
                android:text="Download"
                android:textAllCaps="false"
                android:textColor="@color/lui_white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnCancelDownload"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_outlined"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/lui_amber"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDeleteModel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/btn_outlined"
                android:text="Delete"
                android:textAllCaps="false"
                android:textColor="@color/lui_amber"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="@color/lui_divider" />

        <!-- ==================== Wake Word ==================== -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Hey LUI wake word" android:textColor="@color/lui_white" android:textSize="14sp" />
            <Switch android:id="@+id/wakeWordSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/lui_gray_dark"
            android:textSize="10sp"
            android:text="Always listens for Hey LUI to activate conversation mode. Uses ~2-3%% battery/hour." />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="14dp" android:background="@color/lui_divider" />

        <!-- ==================== Speech ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Speech"
            android:textColor="@color/lui_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Cloud STT and TTS. When off, uses on-device models."
            android:textColor="@color/lui_gray_dark"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable cloud speech" android:textColor="@color/lui_white" android:textSize="14sp" />
            <Switch android:id="@+id/cloudSpeechSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <RadioGroup
            android:id="@+id/speechProviderGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">
            <RadioButton android:id="@+id/rbDeepgram" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Deepgram" android:textColor="@color/lui_white" android:textSize="13sp" />
            <RadioButton android:id="@+id/rbElevenlabs" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="ElevenLabs" android:textColor="@color/lui_white" android:textSize="13sp" />
        </RadioGroup>

        <EditText
            android:id="@+id/speechKeyField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="Speech API key"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="13sp" />

        <!-- Voice selector -->
        <TextView
            android:id="@+id/voiceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Voice"
            android:textColor="@color/lui_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/voiceSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/input_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="@color/lui_divider" />

        <!-- ==================== PersonaPlex ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Real-Time Voice"
            android:textColor="@color/lui_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="PersonaPlex audio-to-audio conversation. Requires a GPU server."
            android:textColor="@color/lui_gray_dark"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable PersonaPlex" android:textColor="@color/lui_white" android:textSize="14sp" />
            <Switch android:id="@+id/personaPlexSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <EditText
            android:id="@+id/personaPlexUrlField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="Server URL (e.g., ws://192.168.1.100:8998)"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/personaPlexRoleField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_background"
            android:hint="Role prompt (e.g., You are a helpful phone assistant)"
            android:inputType="textMultiLine"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/personaPlexStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/lui_gray"
            android:textSize="11sp" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="@color/lui_divider" />

        <!-- ==================== BYOS Bridge ==================== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="BYOS Bridge"
            android:textColor="@color/lui_white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="WebSocket server for remote AI agents. MCP protocol."
            android:textColor="@color/lui_gray_dark"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable bridge" android:textColor="@color/lui_white" android:textSize="14sp" />
            <Switch android:id="@+id/bridgeSwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <!-- Bridge Status -->
        <TextView
            android:id="@+id/bridgeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/lui_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Bridge URL -->
        <TextView
            android:id="@+id/bridgeUrlText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/jetbrains_mono"
            android:textColor="@color/lui_green"
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:visibility="gone" />

        <!-- Bridge Token (tap to copy) -->
        <TextView
            android:id="@+id/bridgeTokenText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/jetbrains_mono"
            android:textColor="@color/lui_amber"
            android:textSize="11sp"
            android:textIsSelectable="true"
            android:visibility="gone" />

        <!-- Permission Tier -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/tierLabel"
            android:layout_marginTop="12dp"
            android:text="Permission tier"
            android:textColor="@color/lui_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <RadioGroup
            android:id="@+id/tierGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:visibility="gone">
            <RadioButton android:id="@+id/rbReadOnly" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Read" android:textColor="@color/lui_white" android:textSize="12sp" />
            <RadioButton android:id="@+id/rbStandard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Standard" android:textColor="@color/lui_white" android:textSize="12sp" />
            <RadioButton android:id="@+id/rbFull" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:buttonTint="@color/lui_gray" android:text="Full" android:textColor="@color/lui_white" android:textSize="12sp" />
        </RadioGroup>

        <TextView
            android:id="@+id/tierDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/lui_gray_dark"
            android:textSize="10sp"
            android:visibility="gone" />

        <!-- Connected Agents -->
        <TextView
            android:id="@+id/agentsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Connected Agents"
            android:textColor="@color/lui_gray"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/agentsListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/jetbrains_mono"
            android:textColor="@color/lui_white"
            android:textSize="11sp"
            android:lineSpacingExtra="4dp"
            android:visibility="gone" />

        <!-- ==================== Relay ==================== -->

        <TextView
            android:id="@+id/relaySection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Remote Relay"
            android:textColor="@color/lui_gray"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/relayDescription"
            android:layout_marginTop="4dp"
            android:text="Connect to a relay server for access beyond your local network."
            android:textColor="@color/lui_gray_dark"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/relayToggleRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable relay" android:textColor="@color/lui_white" android:textSize="13sp" />
            <Switch android:id="@+id/relaySwitch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:thumbTint="@color/lui_white" android:trackTint="@color/lui_gray_dark" />
        </LinearLayout>

        <EditText
            android:id="@+id/relayUrlField"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/input_background"
            android:hint="wss://relay.example.com"
            android:inputType="textUri"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/lui_white"
            android:textColorHint="@color/lui_gray_dark"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/relayStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/lui_gray"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="@color/lui_divider" />

        <!-- Status -->
        <TextView
            android:id="@+id/hubStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/lui_gray"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp" />

        <!-- Test -->
        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_outlined"
            android:text="Test Connections"
            android:textAllCaps="false"
            android:textColor="@color/lui_white"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
