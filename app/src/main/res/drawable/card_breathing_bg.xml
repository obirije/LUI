<?xml version="1.0" encoding="utf-8"?>
<!-- Muted warm "stone" surface — reads lighter than the dark chat canvas
     without the white-page glare of a full-bright cream. Sits between
     dark-mode and meditation-app aesthetics. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#2A2520" />
    <corners android:radius="18dp" />
    <stroke android:width="1dp" android:color="#3A332C" />
</shape>
